{
  "manifest_version": 3,
  "name": "My Exporter",
  "version": "0.1.0",
  "description": "Export chat histories and personal data from various web services",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://claude.ai/*",
    "https://www.google.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "http://127.0.0.1:27123/*",
    "https://127.0.0.1:27124/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*", "https://chat.openai.com/*"],
      "js": ["content_scripts/common.js", "content_scripts/chatgpt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content_scripts/common.js", "content_scripts/gemini.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content_scripts/common.js", "content_scripts/claude.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.google.com/search*"],
      "js": ["content_scripts/common.js", "content_scripts/google_ai_mode.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://perplexity.ai/*", "https://www.perplexity.ai/*"],
      "js": ["content_scripts/common.js", "content_scripts/perplexity.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
